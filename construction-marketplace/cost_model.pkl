import pandas as pd
from sklearn.linear_model import LinearRegression
import pickle

# Fake training data example
data = pd.DataFrame({
    "area": [800, 1000, 1200, 1500],
    "cost": [1200000, 1500000, 1800000, 2200000]
})

X = data[["area"]]
y = data["cost"]

model = LinearRegression()
model.fit(X, y)

pickle.dump(model, open("cost_model.pkl", "wb"))

